#!/usr/bin/env python3
# Stolen graciously from https://github.com/lf-/dotfiles/blob/main/bin/jj-pr
# Thanks, Jade :)
import argparse
import subprocess
import re
import sys

GH_USER_REGEX = re.compile(r"^(https://github\.com/|git@github\.com:)([^/]+)/.*")


def jj_log(template: str, rev: str) -> list[str]:
    return subprocess.check_output(
        [
            "jj",
            "--ignore-working-copy",
            "--quiet",
            "log",
            "--no-graph",
            "--template",
            template,
            "-r",
            rev,
        ],
        text=True,
    ).split(" ")


def jj_remotes() -> dict[str, str]:
    return {
        name: url
        for (name, url) in (
            l.split(" ", 1)
            for l in subprocess.check_output(
                [
                    "jj",
                    "--ignore-working-copy",
                    "--quiet",
                    "git",
                    "remote",
                    "list",
                ],
                text=True,
            ).splitlines()
        )
    }

def copy_to_clipboard(text: str):
    subprocess.run("pbcopy", input=text, text=True, check=True)

def fetch_pr_name(branch: str) -> str:
    pr_view = [
        "gh",
        "pr",
        "view",
        "--json",
        "url,title",
        "--template",
        '{{ .url }}: {{ .title }}',
        branch,
    ]
    res = subprocess.run(pr_view, capture_output=True)
    if res.returncode != 0:
        raise Exception("PR does not exist")
    out = res.stdout.decode('utf-8')
    return out

def fetch_and_copy_pr_name(branch: str):
    pr_name = fetch_pr_name(branch)
    print(pr_name, file=sys.stderr)
    copy_to_clipboard(pr_name)

def main():
    ap = argparse.ArgumentParser(description="Create a pull request with jj")
    ap.add_argument("rev", help="Revision to PR")
    args, rest = ap.parse_known_intermixed_args()

    bookmarks = jj_log("local_bookmarks", args.rev)
    remote_bookmarks = jj_log("remote_bookmarks", args.rev)
    if len(bookmarks) != 1:
        raise ValueError(f"Wrong number of bookmarks there buddy: {bookmarks}")

    # find current pr
    candidate_remote_bookmarks = [
        tuple(bm.rsplit("@", 1)) for bm in remote_bookmarks if not bm.endswith("@git")
    ]

    if len(candidate_remote_bookmarks) > 1:
        raise ValueError(
            f"More bookmarks on this commit than there should be: {candidate_remote_bookmarks}"
        )

    # find the pr then
    bookmark, remote = candidate_remote_bookmarks[0]
    remotes = jj_remotes()
    url = remotes[remote]
    m = GH_USER_REGEX.match(url)
    assert m
    user = m.group(2)

    if len(candidate_remote_bookmarks) == 1:
        try:
            fetch_and_copy_pr_name(bookmark)
            return
        # We didn't find the PR, this isn't a big deal. Let's create it.
        except Exception as e:
            pass
        
    # make a pr!
    res = subprocess.call(["gh", "pr", "create", "--head", bookmark, *rest])
    if res != 0:
        print("PR creation failed", file=sys.stderr)
        return

    fetch_and_copy_pr_name(bookmark)

if __name__ == "__main__":
    main()
