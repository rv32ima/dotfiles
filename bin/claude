#!/usr/bin/env bash
set -eu

# Assume it's in our per-user profile 
CLAUDE="/etc/profiles/per-user/$USER/bin/claude"

if [[ "$(hostname -s)" = "eford-20RW02G" ]]; then
  # Suppress ai-sandbox startup messages
  export AI_SANDBOX_QUIET=1
  ai-sandbox "${CLAUDE}" "$@"
  exit 0
fi

# Hopefully Claude Code is in path somewhere, use that instead
exec "${CLAUDE}" "$@"
