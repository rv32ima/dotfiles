# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host devapp
  User eford
  ForwardAgent yes
  HostName devrestricted-eford.ec2.pin220.com

Host devrestricted
  User eford
  ForwardAgent yes
  HostName devrestricted-eford.ec2.pin220.com

Match host github.com user org-86262824
  PubkeyAcceptedAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-rsa-cert-v01@openssh.com,ecdsa-sha2-nistp256-cert-v01@openssh.com,ecdsa-sha2-nistp384-cert-v01@openssh.com,ecdsa-sha2-nistp521-cert-v01@openssh.com

Host *
  AddKeysToAgent yes

CheckHostIP no
ServerAliveInterval 240
ServerAliveCountMax 10
